{
  "manifest_version": 3,
  "name": "AniTrack",
  "version": "1.0",
  "description": "Automatically track your anime progress on streaming websites.",
  "permissions": [
    "activeTab",
    "notifications",
    "storage"
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
